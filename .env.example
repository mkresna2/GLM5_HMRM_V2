# Copy to .env and adjust for local development.
# Neon via Vercel Marketplace sets DATABASE_URL (pooled) and DIRECT_URL automatically.

# Pooled connection — app runtime (Vercel serverless). Neon/Vercel may name this POSTGRES_PRISMA_URL.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"

# Direct connection — prisma migrate deploy / db push. Map Vercel's DATABASE_URL_UNPOOLED here if needed.
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Python microservices (defaults match docker-compose.services.yml; use Render URL on Vercel)
PRICING_GATEWAY_URL="http://localhost:8001"
HMRM_ENGINE_URL="http://localhost:8002"
ML_SERVICE_URL="http://localhost:8003"
MONTE_CARLO_URL="http://localhost:8004"
OPTIMIZATION_URL="http://localhost:8009"
